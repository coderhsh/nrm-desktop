{
  "$schema": "https://raw.githubusercontent.com/nicedayzhu/tauri-docs-cn/refs/heads/dev/.schemas/config.schema.json",
  "productName": "nrm-desktop",
  "version": "1.0.1",
  "identifier": "com.nrm-desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm ui:dev",
    "beforeBuildCommand": "pnpm sync:version && pnpm ui:build"
  },
  "app": {
    "windows": [
      {
        "title": "nrm-desktop",
        "width": 950,
        "height": 640,
        "minWidth": 950,
        "minHeight": 600,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJERDQ4RjMyREY1RDhDMjQKUldRa2pGM2ZNby9Vdlk3NXdqcnZmOVcwSDZSU2FFVTRxbzRWbUptSTltQ3czeXlCc1VzM2ZTWHQK",
      "endpoints": [
        "https://github.com/coderhsh/nrm-desktop/releases/download/updater/latest.json"
      ]
    }
  }
}
