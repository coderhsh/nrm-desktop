{
  "name": "nrm-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "nrm-desktop - A lightweight desktop GUI for npm registry management, built with Tauri + Vue.",
  "author": "coderhsh",
  "license": "MIT",
  "keywords": [
    "nrm",
    "npm",
    "registry",
    "tauri",
    "vue",
    "desktop"
  ],
  "homepage": "https://github.com/coderhsh/nrm-desktop#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coderhsh/nrm-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/coderhsh/nrm-desktop/issues"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "type": "module",
  "scripts": {
    "tauri:dev": "node ./scripts/tauri-dev-auto-port.mjs",
    "tauri:build": "tauri build",
    "build": "vue-tsc --noEmit && vite build",
    "dev": "vite",
    "tauri": "tauri",
    "icons:generate": "node ./scripts/generate-icons.cjs"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@vueuse/core": "^11.0.0",
    "element-plus": "^2.9.0",
    "pinia": "^2.1.0",
    "vue": "^3.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "vue-demi"
    ]
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@unocss/transformer-directives": "^0.64.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "~5.5.0",
    "unocss": "^0.64.0",
    "vite": "^5.4.0",
    "vue-tsc": "^2.0.0"
  }
}
