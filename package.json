{
  "name": "nrm-desktop",
  "private": true,
  "version": "1.1.1",
  "description": "nrm-desktop - A lightweight desktop GUI for npm registry management, built with Tauri + Vue.",
  "author": "coderhsh",
  "license": "Apache-2.0",
  "keywords": [
    "nrm",
    "npm",
    "registry",
    "tauri",
    "vue",
    "desktop"
  ],
  "homepage": "https://github.com/coderhsh/nrm-desktop#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coderhsh/nrm-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/coderhsh/nrm-desktop/issues"
  },
  "engines": {
    "node": ">=20.19.0 <21.0.0 || >=22.12.0",
    "pnpm": ">=8.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/tauri-dev-auto-port.mjs",
    "build": "node ./scripts/tauri-build-with-output.mjs",
    "build:pretty": "node ./scripts/tauri-build-with-output.mjs",
    "build:win": "node ./scripts/tauri-build-win.mjs",
    "ui:build": "vue-tsc --noEmit && vite build",
    "ui:build:ci": "vite build",
    "typecheck": "vue-tsc --noEmit",
    "ui:dev": "vite",
    "lint": "eslint \"src/**/*.{ts,vue}\" \"*.{ts,js}\"",
    "lint:fix": "eslint \"src/**/*.{ts,vue}\" \"*.{ts,js}\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:updater": "node ./scripts/verify-updater-setup.mjs",
    "tauri": "tauri",
    "update:logo": "node ./scripts/generate-icons.cjs",
    "version": "node ./scripts/sync-app-version.mjs",
    "sync:version": "node ./scripts/sync-app-version.mjs",
    "sync:tags": "node ./scripts/sync-remote-tags.mjs",
    "sync:pull": "node ./scripts/sync-pull.mjs",
    "changelog:context": "node ./scripts/changelog-context.mjs",
    "setup:git-hooks": "node ./scripts/install-git-hooks.mjs",
    "prepare": "node ./scripts/install-git-hooks.mjs"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@vueuse/core": "^12.0.0",
    "element-plus": "^2.9.0",
    "gsap": "^3.15.0",
    "markdown-it": "^14.1.1",
    "pinia": "^3.0.0",
    "vue": "^3.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "vue-demi"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/markdown-it": "^14.1.2",
    "@unocss/preset-attributify": "^66.0.0",
    "@unocss/preset-wind3": "^66.0.0",
    "@unocss/transformer-directives": "^66.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.0.0",
    "happy-dom": "^17.0.0",
    "less": "^4.6.4",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.0.0",
    "unocss": "^66.0.0",
    "unplugin-auto-import": "^19.0.0",
    "unplugin-vue-components": "^28.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0",
    "vue-tsc": "^3.0.0"
  }
}
